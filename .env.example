# Copy to .env and fill in. .env is gitignored — never commit real keys.

# --- LLM provider: ollama (local, default) | anthropic | openai ---
LLM_PROVIDER=ollama
LLM_MODEL=llama3.1                  # try qwen2.5:14b for stronger legal reasoning
OLLAMA_BASE_URL=http://localhost:11434/v1

# Anthropic — only used when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# OpenAI / OpenAI-compatible — only used when LLM_PROVIDER=openai
OPENAI_API_KEY=

# --- Open-source embeddings / rerank (local, multilingual EN/Sinhala/Tamil) ---
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# --- Local storage (zero-config, just file paths) ---
SQLITE_PATH=data/roscribe.db
CHROMA_DIR=data/chroma

# --- Document parsing (v2) ---
# docling (default) = Docling layout-aware parser; legacy = v1 PyMuPDF + Tesseract.
ROSCRIBE_PARSER=docling
TESSERACT_LANGS=eng+sin+tam

# --- Personal repository (your law-school notes) ---
PERSONAL_REPO_DIR=/Users/laksh/Desktop/Final Year April 2026

# --- Access control ---
ROSCRIBE_USERS=you:change-this-password          # comma-separated user:pass pairs
ROSCRIBE_STORAGE_SECRET=                          # random string; roscribe.sh generates one

# --- Google sign-in (optional). OAuth client (Web application) from
# console.cloud.google.com -> APIs & Services -> Credentials. Register BOTH
# redirect URIs: https://<your-public-host>/auth/google and
# http://localhost:8080/auth/google. Button shows once both values are set.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ROSCRIBE_OAUTH_ALLOWED_EMAILS=you@example.com     # comma-separated allowlist
